# LiteLLM proxy connection
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-you...n

# Fusion service config
HOST=0.0.0.0
PORT=4040

# Optional: API key clients must send to use this service
# FUSION_API_KEY=***

# Default models (overridable per-request via fusion_config)
DEFAULT_PANEL=anthropic/claude-sonnet-4,openai/gpt-4o,google/gemini-2.5-pro
DEFAULT_JUDGE=anthropic/claude-sonnet-4
DEFAULT_OUTER_MODEL=anthropic/claude-sonnet-4

# Web search
# Get a Brave Search API key: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=
# Falls back to DuckDuckGo API if Brave key is empty or fails
WEB_SEARCH_ENABLED=true
