# Logging (debug | info | warn | error)
LOG_LEVEL=info

# LiteLLM proxy connection
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=sk-you...n

# Fusion service config
HOST=0.0.0.0
PORT=4040

# Optional: API key clients must send to use this service
# FUSION_API_KEY=***

# Default models (overridable per-request via fusion_config)
DEFAULT_PANEL=deepseek-v4-flash,mimo-v2.5,gpt-5.4,gemini-3.5-flash
DEFAULT_JUDGE=deepseek-v4-flash
DEFAULT_OUTER_MODEL=mimo-v2.5

# Web search
# When enabled, the outer model receives a search tool and decides when to invoke it.
# Get a Brave Search API key: https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=
# Falls back to DuckDuckGo API if Brave key is empty or fails
WEB_SEARCH_ENABLED=true
